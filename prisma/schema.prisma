generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  
}

model User {
  id            Int      @id @default(autoincrement())
  name          String
  email         String   @unique
  password      String?
  googleId      String?  @unique
  resetToken    String?
  resetTokenExp DateTime?

  isOnline      Boolean  @default(false)
  lastSeen      DateTime?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}